{
  "name": "assignment-team-task-manager-full-stack",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "start": "npm run start --workspace server",
    "build": "npm run build --workspace client",
    "check": "npm run check --workspace server && npm run build --workspace client",
    "seed": "npm run seed --workspace server"
  },
  "workspaces": [
    "server",
    "client"
  ],
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
